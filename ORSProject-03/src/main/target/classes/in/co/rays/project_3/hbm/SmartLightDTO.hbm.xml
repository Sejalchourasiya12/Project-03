<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.SmartLightDTO" table="ST_SMARTLIGHTDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="lightCode" type="java.lang.String" access="field">
            <column name="LIGHTCODE" />
        </property>
        <property name="roomName" type="java.lang.String" access="field">
            <column name="ROOMNAME" />
        </property>
        <property name="brightnessLevel" type="java.lang.Integer" access="field">
            <column name="BRIGHTNESSLEVEL" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>