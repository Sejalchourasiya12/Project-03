<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.BugTrackingDTO" table="ST_BUGTRACKINGDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="projectName" type="java.lang.String" access="field">
            <column name="PROJECTNAME" />
        </property>
        <property name="severity" type="java.lang.String" access="field">
            <column name="SEVERITY" />
        </property>
        <property name="assignedTo" type="java.lang.String" access="field">
            <column name="ASSIGNEDTO" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>