<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.BloodBankDTO" table="ST_BLOODBANKDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="donorName" type="java.lang.String" access="field">
            <column name="DONORNAME" />
        </property>
        <property name="bloodGroup" type="java.lang.String" access="field">
            <column name="BLOODGROUP" />
        </property>
        <property name="available" type="int" access="field">
            <column name="AVAILABLEUNITS" />
        </property>
        <property name="contactNumber" type="java.lang.String" access="field">
            <column name="CONTACTNUMBER" />
        </property>
    </class>
</hibernate-mapping>