<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.EnergyConsumptionDTO" table="ST_ENERGYCONSUMPTIONDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="energyCode" type="java.lang.String" access="field">
            <column name="ENERGYCODE" />
        </property>
        <property name="deviceName" type="java.lang.String" access="field">
            <column name="DEVICENAME" />
        </property>
        <property name="unitsConsumed" type="java.lang.String" access="field">
            <column name="UNITSCONSUMED" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>