<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.ATMDTO" table="ST_ATMDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="securityCode" type="java.lang.String" access="field">
            <column name="SECURITYCODE" />
        </property>
        <property name="bankName" type="java.lang.String" access="field">
            <column name="BANKNAME" />
        </property>
        <property name="location" type="java.lang.String" access="field">
            <column name="LOCATION" />
        </property>
        <property name="cashAvailable" type="java.lang.String" access="field">
            <column name="CASHAVAILABLE" />
        </property>
    </class>
</hibernate-mapping>