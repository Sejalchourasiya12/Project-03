<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.PodcastDTO" table="ST_PODCASTDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="podcastCode" type="java.lang.String" access="field">
            <column name="PODCASTCODE" />
        </property>
        <property name="podcastTitle" type="java.lang.String" access="field">
            <column name="PODCASTTITLE" />
        </property>
        <property name="hostName" type="java.lang.String" access="field">
            <column name="HOSTNAME" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>