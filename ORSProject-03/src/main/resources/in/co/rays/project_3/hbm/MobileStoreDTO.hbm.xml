<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.MobileStoreDTO" table="ST_MOBILESTOREDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="brandName" type="java.lang.String" access="field">
            <column name="BRANDNAME" />
        </property>
        <property name="modelName" type="java.lang.String" access="field">
            <column name="MODELNAME" />
        </property>
        <property name="ramSize" type="java.lang.String" access="field">
            <column name="RAMSIZE" />
        </property>
        <property name="price" type="java.lang.String" access="field">
            <column name="PRICE" />
        </property>
    </class>
</hibernate-mapping>