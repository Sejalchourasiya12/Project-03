<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.DroneDeliveryDTO" table="ST_DRONEDELIVERYDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="droneCode" type="java.lang.String" access="field">
            <column name="DRONECODE" />
        </property>
        <property name="operatorName" type="java.lang.String" access="field">
            <column name="OPERATORNAME" />
        </property>
        <property name="deliveryZone" type="java.lang.String" access="field">
            <column name="DELIVERYZONE" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>