<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.AIRecommendationDTO" table="ST_AIRECOMMENDATIONDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="recommendationCode" type="java.lang.String" access="field">
            <column name="RECOMMENDATIONCODE" />
        </property>
        <property name="userName" type="java.lang.String" access="field">
            <column name="USERNAME" />
        </property>
        <property name="recommendationType" type="java.lang.String" access="field">
            <column name="RECOMMENDATIONTYPE" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>