<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.EmployeePayrollDTO" table="ST_EMPLOYEEPAYROLLDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="employeeName" type="java.lang.String" access="field">
            <column name="EMPLOYEENAME" />
        </property>
        <property name="department" type="java.lang.String" access="field">
            <column name="DEPARTMENT" />
        </property>
        <property name="salary" type="java.lang.String" access="field">
            <column name="SALARY" />
        </property>
        <property name="bonus" type="java.lang.String" access="field">
            <column name="BONUS" />
        </property>
    </class>
</hibernate-mapping>