<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.GenderDTO" table="ST_GENDERDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="genderCode" type="java.lang.String" access="field">
            <column name="GENDERCODE" />
        </property>
        <property name="genderType" type="java.lang.String" access="field">
            <column name="GENDERTYPE" />
        </property>
        <property name="description" type="java.lang.String" access="field">
            <column name="DESCRIPTION" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>