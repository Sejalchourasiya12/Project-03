<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.CloudStorageDTO" table="ST_CLOUDSTORAGEDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="fileName" type="java.lang.String" access="field">
            <column name="FILENAME" />
        </property>
        <property name="fileSize" type="java.lang.String" access="field">
            <column name="FILESIZE" />
        </property>
        <property name="uploadDate" type="java.util.Date" access="field">
            <column name="UPLOADDATE" />
        </property>
        <property name="storageType" type="java.lang.String" access="field">
            <column name="STORAGETYPE" />
        </property>
    </class>
</hibernate-mapping>