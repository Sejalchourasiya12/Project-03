<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.VehicleInsuranceDTO" table="ST_VEHICLEINSURANCEDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="ownerName" type="java.lang.String" access="field">
            <column name="OWNERNAME" />
        </property>
        <property name="vehicleNumber" type="java.lang.String" access="field">
            <column name="VEHICLENUMBER" />
        </property>
        <property name="vehicleType" type="java.lang.String" access="field">
            <column name="VEHICLETYPE" />
        </property>
        <property name="insuranceCompany" type="java.lang.String" access="field">
            <column name="INSURANCECOMPANY" />
        </property>
    </class>
</hibernate-mapping>