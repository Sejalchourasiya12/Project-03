<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.AchievementDTO" table="ST_ACHIEVEMENTDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="achievementCode" type="java.lang.String" access="field">
            <column name="ACHIEVEMENTCODE" />
        </property>
        <property name="achievementName" type="java.lang.String" access="field">
            <column name="ACHIEVEMENTNAME" />
        </property>
        <property name="earnedBy" type="java.lang.String" access="field">
            <column name="EARNEDBY" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>