<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.WeatherAlertDTO" table="ST_WEATHERALERTDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="alertCode" type="java.lang.String" access="field">
            <column name="ALERTCODE" />
        </property>
        <property name="cityName" type="java.lang.String" access="field">
            <column name="CITYNAME" />
        </property>
        <property name="temperature" type="java.lang.String" access="field">
            <column name="TEMPERATURE" />
        </property>
        <property name="status" type="java.lang.String" access="field">
            <column name="STATUS" />
        </property>
    </class>
</hibernate-mapping>