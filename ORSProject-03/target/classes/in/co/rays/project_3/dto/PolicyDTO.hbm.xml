<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="in.co.rays.project_3.dto.PolicyDTO" table="ST_POLICYDTO">
        <id name="id" type="java.lang.Long" access="field">
            <column name="ID" />
            <generator class="increment" />
        </id>
        <property name="policyCode" type="java.lang.String" access="field">
            <column name="POLICYCODE" />
        </property>
        <property name="policyName" type="java.lang.String" access="field">
            <column name="POLICYNAME" />
        </property>
        <property name="premiumAmount" type="java.lang.String" access="field">
            <column name="PREMIUMAMOUNT" />
        </property>
        <property name="policyStatus" type="java.lang.String" access="field">
            <column name="POLICYSTATUS" />
        </property>
    </class>
</hibernate-mapping>